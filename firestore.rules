rules_version = '2';
// ---------------------------------------------------------------
// Aqro  Firestore Security Rules
// ---------------------------------------------------------------
// Role hierarchy (stored in users/{uid}.role):
//   "citizen"      — public user: file and read own reports
//   "municipality" — municipal officer: read/update all reports
//   "admin"        — full access
// ---------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid
    }
    // Single get() — avoids the exists()+get() double-read which can cause
    // timing / evaluation issues. Returns '' if the doc is missing.
    function userRole() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && u != null ? u.data.get('role', '') : '';
    }
    // Elevated roles — "admin" OR "municipality"
    function isMunicipal() {
      return isSignedIn() && userRole() in ['admin', 'municipality']
    }
    function isAdmin() {
      return isSignedIn() && userRole() == 'admin'
    }
    function isCitizen() {
      return isSignedIn() && userRole() == 'citizen'
    }

    // ── User profiles ──────────────────────────────────────── 
    match /users/{uid} {
      // Public read — required for the Civic Impact Leaderboard
      allow read:   if true;
      allow create: if isOwner(uid);
      // Citizens may update their own profile; admin/municipality may update
      // any profile (needed to award points + increment cleared_complaints).
      allow update: if isOwner(uid) || isMunicipal();
      allow delete: if false;
    }

    // ── Reports (complaints) ───────────────────────────────── 
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.created_by == request.auth.uid;
      // Public read for heatmap / landing page stats
      allow read:   if true;
      allow list:   if true;
      // Citizens: update own while pending; Municipal/Admin: update any
      allow update: if isSignedIn()
                    && (
                      isMunicipal()
                      || resource.data.created_by == request.auth.uid
                    );
      // Municipal officers and admins may delete reports (e.g. bulk clear)
      allow delete: if isMunicipal();
    }

    // ── Daily summaries (admin read-only) ──────────────────── 
    match /daily_summary/{docId} {
      allow read:  if isMunicipal();
      allow write: if false;
    }

    // ── Predictions ────────────────────────────────────────── 
    match /predictions/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Notifications ──────────────────────────────────────── 
    match /notifications/{notifId} {
      // Citizens read their own; municipality read all
      allow read:   if isSignedIn()
                    && (resource.data.user_id == request.auth.uid || isMunicipal());
      allow create: if isMunicipal();
      // Citizen can mark review_submitted / delete their own after review
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // ── Teams ──────────────────────────────────────────────── 
    match /teams/{teamName} {
      allow read:   if true;
      // Any signed-in user can update (needed for citizen rating bonus via transaction)
      allow update: if isSignedIn();
      // Create only by municipality (first-clear transaction runs as municipality officer)
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ── Reviews ────────────────────────────────────────────── 
    match /reviews/{reviewId} {
      allow create: if isSignedIn()
                    && request.resource.data.user_id == request.auth.uid;
      allow read:   if isSignedIn()
                    && (resource.data.user_id == request.auth.uid || isMunicipal());
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Heatmap aggregates ─────────────────────────────────── 
    match /heatmap/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Leaderboard ────────────────────────────────────────── 
    match /leaderboard/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Workforce / dispatch records ───────────────────────── 
    match /workforce/{docId} {
      allow read:  if isMunicipal();
      allow write: if isMunicipal();
    }
  }
}