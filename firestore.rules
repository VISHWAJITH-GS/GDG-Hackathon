rules_version = '2';
// ---------------------------------------------------------------
// M-Clean Firestore Security Rules
// ---------------------------------------------------------------
// Role hierarchy (stored in users/{uid}.role):
//   "citizen"      — public user: file and read own reports
//   "municipality" — municipal officer: read/update all reports
//   "admin"        — full access
// ---------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
    }
    function isSignedIn() {
      return request.auth != null
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid
    }
    // Elevated roles — "admin" OR "municipality"
    function isMunicipal() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserDoc().data.role in ['admin', 'municipality']
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserDoc().data.role == 'admin'
    }
    function isCitizen() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserDoc().data.role == 'citizen'
    }

    // ── User profiles ──────────────────────────────────────── 
    match /users/{uid} {
      // Public read — required for the Civic Impact Leaderboard
      allow read:   if true;
      allow create: if isOwner(uid);
      // Citizens may update their own profile; admin/municipality may update
      // any profile (needed to award points + increment cleared_complaints).
      allow update: if isOwner(uid) || isMunicipal();
      allow delete: if false;
    }

    // ── Reports (complaints) ───────────────────────────────── 
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.created_by == request.auth.uid;
      // Public read for heatmap / landing page stats
      allow read:   if true;
      allow list:   if true;
      // Citizens: update own while pending; Municipal/Admin: update any
      allow update: if isSignedIn()
                    && (
                      isMunicipal()
                      || resource.data.created_by == request.auth.uid
                    );
      allow delete: if false;
    }

    // ── Daily summaries (admin read-only) ──────────────────── 
    match /daily_summary/{docId} {
      allow read:  if isMunicipal();
      allow write: if false;
    }

    // ── Predictions ────────────────────────────────────────── 
    match /predictions/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Notifications ──────────────────────────────────────── 
    match /notifications/{notifId} {
      allow read:   if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isMunicipal());
      allow create: if isMunicipal();
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Heatmap aggregates ─────────────────────────────────── 
    match /heatmap/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Leaderboard ────────────────────────────────────────── 
    match /leaderboard/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Workforce / dispatch records ───────────────────────── 
    match /workforce/{docId} {
      allow read:  if isMunicipal();
      allow write: if isMunicipal();
    }
  }
}