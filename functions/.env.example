# ============================================================
# Aqro  Firebase Cloud Functions - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Project ID (same as Firebase project ID)
GCP_PROJECT_ID=your_gcp_project_id_here

# Firestore collection where reports are stored
FIRESTORE_COLLECTION=reports

# Gemini model to use (gemini-1.5-pro recommended for structured output)
GEMINI_MODEL=gemini-1.5-pro
