# ============================================
# Madurai Civic Intelligence - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# --- Google Cloud / Firebase ---
GOOGLE_CLOUD_PROJECT=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- Vertex AI ---
VERTEX_AI_LOCATION=asia-south1

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Google Speech-to-Text ---
# Uses Application Default Credentials (ADC) via service account — no extra key needed

# --- Notification Services ---
# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# SendGrid (for email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=alerts@madurai-municipal.gov.in

# Zonal Officer Contact
ZONAL_OFFICER_PHONE=+9194xxxxxxxx
ZONAL_OFFICER_EMAIL=zonal.officer@madurai-municipal.gov.in
