rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Complaints — citizens create; municipal officers read/update any
    match /complaints/{complaintId} {
      allow create: if true;
      allow read:   if request.auth != null;
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          in ["admin", "municipality"];
      allow delete: if false;
    }

    // Reports (Aqro  reports collection)
    match /reports/{reportId} {
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          in ["admin", "municipality"];
      allow create: if request.auth != null;
    }

    // Verifications — restricted to authenticated workers
    match /verifications/{verificationId} {
      allow read, write: if request.auth != null;
    }

    // Hazard Escalations — read-only for authenticated users
    match /hazardEscalations/{escalationId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }

    // Disposal Units — public read, admin write
    match /disposalUnits/{unitId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Heritage Restorations — public read
    match /heritageRestorations/{jobId} {
      allow read: if true;
      allow write: if false; // Only backend
    }
  }
}
