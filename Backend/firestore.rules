rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Complaints — public write (citizen reporting), restricted read
    match /complaints/{complaintId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Verifications — restricted to authenticated workers
    match /verifications/{verificationId} {
      allow read, write: if request.auth != null;
    }

    // Hazard Escalations — read-only for authenticated users
    match /hazardEscalations/{escalationId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }

    // Disposal Units — public read, admin write
    match /disposalUnits/{unitId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Heritage Restorations — public read
    match /heritageRestorations/{jobId} {
      allow read: if true;
      allow write: if false; // Only backend
    }
  }
}
